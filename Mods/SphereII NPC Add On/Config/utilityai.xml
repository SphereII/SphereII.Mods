                <consideration class="NotInWeaponRangeV4, SCore" action_index="0" />
                <consideration class="CanSeeTargetV4, SCore"/>
                <consideration class="SelfNotHasBuffV4, SCore" buffs="buffNPCModFullControlMode,IsHealing,buffHitStun"/>
                <consideration class="NotHasOrderV4, SCore" order="Stay"/>
            </action>
            <action name="MeleeAttackEntityBasic" weight="5">
