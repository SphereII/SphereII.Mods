<configs>
    
    <!-- V4 AI Packages: use these with EntityAliveSDXV4-based NPCs.
         All SCore task/consideration classes use the V4 suffix.
         Package names mirror 0-XNPCCore / Blooms Family Farming with a V4 suffix.
         Usage in entityclasses.xml: <property name="AIPackages" value="NPCModCoreV4, NPCModNPCHiredV4, NPCModNPCMeleeBasicV4"/> -->
    <append xpath="/utility_ai/ai_packages">

        <!-- ═══════════════════════════════════════════════════════
             CORE PACKAGES  (one required per NPC)
             ═══════════════════════════════════════════════════════ -->

        <ai_package name="NPCModCoreV4">
            <action name="DefaultAction" weight=".5" entity_filter="IsSelf">
                <task class="IdleSDXV4, SCore" />
            </action>
            <action name="Wander" weight="1" entity_filter="IsSelf">
                <task class="WanderSDXV4, SCore"/>
                <consideration class="NotHasOrderV4, SCore" order="Stay"/>
                <consideration class="EnemyNotNearV4, SCore" distance="30" />
            </action>
            <action name="Chat" weight="2" entity_filter="IsPlayer">
                <task class="IdleSDXV4, SCore" OnStartAddBuffs="RandomIdle" OnStopRemoveBuffs="RandomIdle" />
                <consideration class="EnemyNotNearV4, SCore" distance="10" />
                <consideration class="TargetDistance" flip_x="true" min="1" max="4" curve="threshold" />
            </action>
            <action name="Stay" weight="2" entity_filter="IsSelf">
                <task class="GuardV4, SCore" />
                <consideration class="EnemyNotNearV4, SCore" />
                <consideration class="HasOrderV4, SCore" order="Stay"/>
            </action>
            <action name="Guard" weight="2" entity_filter="IsSelf">
                <task class="GuardV4, SCore" />
                <consideration class="HasOrderV4, SCore" order="Guard" />
            </action>
            <action name="Flee" weight="6" entity_filter="IsEnemy">
                <task class="FleeFromTarget" max_distance="30"/>
                <consideration class="SelfHasCVarV4, SCore" cvar="$Timid" value="1"/>
                <consideration class="TargetDistance" min="0" max="15" curve="threshold"/>
                <consideration class="SelfVisible"/>
            </action>
        </ai_package>

        <ai_package name="NPCModCoreNoChatV4">
            <action name="DefaultAction" weight=".5" entity_filter="IsSelf">
                <task class="IdleSDXV4, SCore" />
            </action>
            <action name="WanderInside" weight="1" entity_filter="IsSelf">
                <task class="WanderSDXV4, SCore"/>
                <consideration class="IsInsideV4, SCore" />
                <consideration class="NotHasOrderV4, SCore" order="Stay"/>
            </action>
            <action name="WanderOutside" weight="1" entity_filter="IsSelf">
                <task class="WanderSDXV4, SCore"/>
                <consideration class="IsNotInsideV4, SCore" />
                <consideration class="NotHasOrderV4, SCore" order="Stay"/>
                <consideration class="EnemyNotNearV4, SCore" distance="30" />
            </action>
            <action name="NoChatIdle" weight="1" entity_filter="IsPlayer">
                <task class="IdleSDXV4, SCore" />
                <consideration class="HasOrderV4, SCore" order="Stay"/>
            </action>
            <action name="Guard" weight="2" entity_filter="IsSelf">
                <task class="GuardV4, SCore" />
                <consideration class="HasOrderV4, SCore" order="Guard" />
            </action>
            <action name="Flee" weight="6" entity_filter="IsEnemy">
                <task class="FleeFromTarget" max_distance="30"/>
                <consideration class="SelfHasCVarV4, SCore" cvar="$Timid" value="1"/>
                <consideration class="TargetDistance" min="0" max="15" curve="threshold"/>
                <consideration class="SelfVisible"/>
            </action>
        </ai_package>

        <!-- ═══════════════════════════════════════════════════════
             HIRED / FOLLOW PACKAGE
             ═══════════════════════════════════════════════════════ -->

        <ai_package name="NPCModNPCHiredV4" entity_filter="IsLeader">
            <action name="TooCloseInside" weight="3">
                <task class="BackupFromTargetSDXV4, SCore" max_distance="2.5"/>
                <consideration class="EnemyNotNearV4, SCore" distance="20" />
                <consideration class="IsInsideV4, SCore" />
                <consideration class="TargetDistance" flip_x="true" min="0" max="2.5" />
                <consideration class="NotHasOrderV4, SCore" order="Stay"/>
            </action>
            <action name="TooCloseOutside" weight="3">
                <task class="BackupFromTargetSDXV4, SCore" max_distance="2.5"/>
                <consideration class="EnemyNotNearV4, SCore" distance="20" />
                <consideration class="IsNotInsideV4, SCore" />
                <consideration class="TargetDistance" flip_x="true" min="0" max="1" />
                <consideration class="NotHasOrderV4, SCore" order="Stay"/>
            </action>
            <action name="LeaderFollow" weight="2">
                <task class="FollowSDXV4, SCore" OnStartAddBuffs="NPCpegasus" OnStopRemoveBuffs="NPCpegasus"/>
                <consideration class="HasOrderV4, SCore" order="Follow"/>
                <consideration class="TargetDistance" min="20" max="40" curve="threshold" />
                <consideration class="EnemyNotNearV4, SCore" distance="30" />
            </action>
            <action name="LeaderFollowSlow" weight="2">
                <task class="FollowSDXV4, SCore"/>
                <consideration class="HasOrderV4, SCore" order="Follow"/>
                <consideration class="TargetDistance" min="2.5" max="20" curve="threshold"/>
                <consideration class="EnemyNotNearV4, SCore" distance="20" />
            </action>
        </ai_package>

